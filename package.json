{
  "name": "australian-library-browser",
  "version": "1.0.0",
  "description": "Collect material from Australian collections into self-describing research libraries.",
  "author": "Patrick Morrison",
  "private": true,
  "license": "UNLICENSED",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "mcp:start": "node mcp/server.js",
    "test:mcp": "node scripts/test-mcp.js",
    "test:store": "node scripts/test-project-store-edge-cases.js",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:live",
    "test:e2e:smoke": "node scripts/run-with-retry.js scripts/test-electron-smoke.js 2",
    "test:e2e:live": "node scripts/run-with-retry.js scripts/test-live-swan-river-wrecks.js 2 && node scripts/run-with-retry.js scripts/test-live-wellington-dam-image-search.js 2 && node scripts/run-with-retry.js scripts/test-live-library-workflow.js 2 && node scripts/run-with-retry.js scripts/test-live-inline-sidebar-actions.js 2",
    "test:e2e:slwa-image": "node scripts/run-with-retry.js scripts/test-live-wellington-dam-images.js 2",
    "test:fixtures": "node scripts/test-source-fixtures.js",
    "test:audit-live": "node scripts/audit-live-projects.js",
    "inspect:pages": "node scripts/inspect-pages.js",
    "open:tabs": "node scripts/open-tabs-cli.js",
    "debug:inline": "node scripts/debug-inline-actions.js",
    "profile:flow": "node scripts/profile-collection-flow.js",
    "profile:search": "node scripts/profile-rapid-search.js",
    "probe:source": "node scripts/probe-source.js",
    "collect:curated": "node scripts/collect-curated-projects.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "csv-parse": "^6.2.1",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.1.0"
  },
  "devDependencies": {
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "playwright": "^1.52.0"
  },
  "build": {
    "appId": "au.patrickmorrison.australianlibrarybrowser",
    "productName": "The Australian Library Browser",
    "icon": "logo.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "lib/**/*",
      "mcp/**/*",
      "scripts/**/*",
      "package.json",
      "README.md",
      "COPYRIGHT.md"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "zip"
      ]
    }
  }
}
